{
  "manifest_version": 3,
  "name": "En/Decoder and Extender",
  "version": "0.1",
  "description": "PoC encoder, decoder and URL extender.",
  "permissions": ["sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Decoder Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
