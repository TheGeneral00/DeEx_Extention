{
  "manifest_version": 3,
  "name": "En/Decoder and Extender",
  "version": "0.1",
  "description": "PoC encoder, decoder and URL extender.",
  "permissions": ["sidePanel", "webRequest", "declarativeNetRequest", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Decoder Sidebar"
  },
  "side_panel": {
    "default_path": "/sidebar/sidebar.html"
  },
  "content_security_policy": {
          "extension_pages": "default_src 'self'"
  }
}
